# Email provider for demo bookings (optional — without these, bookings are logged server-side)
RESEND_API_KEY=
BOOKING_TO_EMAIL=

# External sign-up URL for the "Get Started" CTA (optional — falls back to /book-demo)
NEXT_PUBLIC_SIGNUP_URL=

# External booking API endpoint for the demo form POST (optional — falls back to
# the internal /api/book-demo route). Set this to the real API URL once available.
NEXT_PUBLIC_BOOKING_ENDPOINT=
